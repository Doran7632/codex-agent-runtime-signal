#!/usr/bin/env bash
set -euo pipefail

ROOT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
RELEASE_BIN="$ROOT_DIR/dist/bin/codex-agent-runtime-signal"
DEBUG_BIN="$ROOT_DIR/.build/debug/codex-agent-runtime-signal"

if [[ -x "${CODEX_AGENT_RUNTIME_SIGNAL_BIN:-}" ]]; then
  exec "$CODEX_AGENT_RUNTIME_SIGNAL_BIN" "$@"
fi

if [[ -x "$DEBUG_BIN" && ( ! -x "$RELEASE_BIN" || "$DEBUG_BIN" -nt "$RELEASE_BIN" ) ]]; then
  exec "$DEBUG_BIN" "$@"
fi

if [[ -x "$RELEASE_BIN" ]]; then
  exec "$RELEASE_BIN" "$@"
fi

if [[ -x "$DEBUG_BIN" ]]; then
  exec "$DEBUG_BIN" "$@"
fi

cat >&2 <<EOF
codex-agent-runtime-signal binary is not installed.

Run:
  $ROOT_DIR/script/install_cli.sh
EOF
exit 127
